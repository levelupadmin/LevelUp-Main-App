# LevelUp Studio worker — Vercel env vars (set in the Vercel project, not committed)

# LevelUp Supabase (prod ref ivkvluezuiojovpotlyb)
SUPABASE_URL=https://ivkvluezuiojovpotlyb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # service-role key — server only, never client
SUPABASE_ANON_KEY=                # anon key — used to verify a user's access token via /auth/v1/user

# Instagram fetch (Apify). Self-host yt-dlp is the eventual default; Apify is the
# zero-maintenance path we launch on (its free credit covers ~10k reels/mo).
APIFY_TOKEN=

# Transcription (Cloudflare Workers AI Whisper)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN_WORKERS=

# Cron protection — Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`
CRON_SECRET=

# Tuning (optional)
STUDIO_DAILY_CAP=2000             # global daily processed-reel ceiling (NOT per-user)
STUDIO_DRAIN_LIMIT=5              # reels processed per cron tick
