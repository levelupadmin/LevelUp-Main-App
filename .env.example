# LevelUp Main App — environment template.
# Copy to `.env` (gitignored) and fill in. All client vars are VITE_-prefixed
# and are COMPILED INTO THE BROWSER BUNDLE — never put a server secret here.
# Server secrets (service_role key, RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET,
# VDOCIPHER_API_KEY, MSG91 auth key, DB password) live ONLY in Supabase Edge
# Function secrets and iCloud, never in this file or the repo.

# ── Supabase (public anon/publishable values) ──
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"

# ── MSG91 phone-OTP widget (public widget identifiers) ──
VITE_MSG91_WIDGET_ID="your-widget-id"
VITE_MSG91_TOKEN_AUTH="your-widget-token"

# ── Error monitoring (optional; Sentry browser DSN is safe to expose) ──
# Leave empty in dev. Set in the Vercel production env to enable reporting.
VITE_SENTRY_DSN=""

# ── DEV ONLY — never set in a production build ──
# Activates the admin auth bypass, and only when served from localhost.
# VITE_DEV_ADMIN_BYPASS="true"
