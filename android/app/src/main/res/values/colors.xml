<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      App background / splash fill.

      Matches the web app background (#0a0a0a) and the index.html
      theme-color so there is NO white flash in the window between the
      native splash dismissing and the WebView painting its first frame.
      Referenced by AppTheme.NoActionBar (post-splash windowBackground)
      and AppTheme.NoActionBarLaunch (splash screen background).
    -->
    <color name="splashBackground">#0A0A0A</color>
</resources>
